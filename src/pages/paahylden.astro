---
import MainLayout from "../layouts/MainLayout.astro";
import Heading from "../components/Heading.astro";
import Text from "../components/Text.astro";
import ProductCard from "../components/ProductCard.astro";
---

<MainLayout title="På hylden">
  <main class="container mx-auto p-4 mt-100">
    <Heading htmlheading="h1">Lav noget flot!</Heading>
    <Text teksttype="brødtekst">Så bliver Anders glad:-)</Text>

    <ProductCard
      imageSrc="/img/PlaceHolderProduct1.png"
      imageAlt="Flaske vin"
      title="Château de la Tour"
      pris="199,95 DKK"
      buttonText="Læg i kurv"
      showBadge={true}
      badgeText="Nyhed"
      badgeColor="badge-primary"
      quantity={1}
    />
  </main>
</MainLayout>
