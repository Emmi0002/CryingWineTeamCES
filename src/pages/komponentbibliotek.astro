---
import MainLayout from "../layouts/MainLayout.astro";
import Heading from "../components/Heading.astro";
import Text from "../components/Text.astro";
import Link from "../components/Link.astro";
import Button from "../components/Button.astro";
import { Image } from "astro:assets";
import thumbsup from "../assets/images/thumbsup.png";
---

<MainLayout title="Titel">
  <main class="container mx-auto p-4">
    <Heading htmlheading="h1" size="large">Komponentbibliotek</Heading>
    <Text stylingclasses="italic"
      >Her kan du finde alle de komponenter, der er brugt i dette projekt.</Text
    >
    <hr class="my-4" />
    <!-- start på typografi -->
    <section class="my-15">
      <div class="my-5">
        <Heading htmlheading="h2" size="medium">
          Text komponenter - alle teksttyper
        </Heading>
      </div>

      <!-- Headline -->
      <div class="my-10 flex flex-col gap-3">
        <Text teksttype="headline" weight="light" color="body">
          Headline - Light - Body
        </Text>

        <Text teksttype="headline" weight="regular" color="body">
          Headline - Regular - Body
        </Text>

        <Text teksttype="headline" weight="bold" color="body">
          Headline - Bold - Body
        </Text>

        <Text teksttype="headline" weight="bold" color="primary">
          Headline - Bold - Primary
        </Text>

        <Text teksttype="headline" weight="bold" color="secondary">
          Headline - Bold - Secondary
        </Text>

        <Text
          teksttype="headline"
          weight="bold"
          color="negative"
          stylingclasses="bg-primary p-2 rounded-2xl block"
        >
          Headline - Bold - Negative
        </Text>
      </div>

      <!-- Body -->
      <div class="my-10 flex flex-col gap-3">
        <Text teksttype="body" weight="light" color="body">
          Body - Light - Body
        </Text>

        <Text teksttype="body" weight="regular" color="body">
          Body - Regular - Body
        </Text>

        <Text teksttype="body" weight="bold" color="body">
          Body - Bold - Body
        </Text>

        <Text teksttype="body" weight="bold" color="primary">
          Body - Bold - Primary
        </Text>

        <Text teksttype="body" weight="bold" color="secondary">
          Body - Bold - Secondary
        </Text>

        <Text
          teksttype="body"
          weight="bold"
          color="negative"
          stylingclasses="bg-primary p-2 rounded-2xl block"
        >
          Body - Bold - Negative
        </Text>
      </div>

      <!-- Subtitle -->
      <div class="my-10 flex flex-col gap-3">
        <Text teksttype="subtitle" weight="light" color="body">
          Subtitle - Light - Body
        </Text>

        <Text teksttype="subtitle" weight="regular" color="body">
          Subtitle - Regular - Body
        </Text>

        <Text teksttype="subtitle" weight="bold" color="body">
          Subtitle - Bold - Body
        </Text>

        <Text teksttype="subtitle" weight="bold" color="primary">
          Subtitle - Bold - Primary
        </Text>

        <Text teksttype="subtitle" weight="bold" color="secondary">
          Subtitle - Bold - Secondary
        </Text>

        <Text
          teksttype="subtitle"
          weight="bold"
          color="negative"
          stylingclasses="bg-primary p-2 rounded-2xl block"
        >
          Subtitle - Bold - Negative
        </Text>
      </div>

      <!-- Caption -->
      <div class="my-10 flex flex-col gap-3">
        <Text teksttype="caption" weight="light" color="body">
          Caption - Light - Body
        </Text>

        <Text teksttype="caption" weight="regular" color="body">
          Caption - Regular - Body
        </Text>

        <Text teksttype="caption" weight="bold" color="body">
          Caption - Bold - Body
        </Text>

        <Text teksttype="caption" weight="bold" color="primary">
          Caption - Bold - Primary
        </Text>

        <Text teksttype="caption" weight="bold" color="secondary">
          Caption - Bold - Secondary
        </Text>

        <Text
          teksttype="caption"
          weight="bold"
          color="negative"
          stylingclasses="bg-primary px-2 rounded-2xl block"
        >
          Caption - Bold - Negative
        </Text>
      </div>

      <!-- Footnote -->
      <div class="my-10 flex flex-col gap-3">
        <Text teksttype="footnote" weight="light" color="body">
          Footnote - Light - Body
        </Text>

        <Text teksttype="footnote" weight="regular" color="body">
          Footnote - Regular - Body
        </Text>

        <Text teksttype="footnote" weight="bold" color="body">
          Footnote - Bold - Body
        </Text>

        <Text teksttype="footnote" weight="bold" color="primary">
          Footnote - Bold - Primary
        </Text>

        <Text teksttype="footnote" weight="bold" color="secondary">
          Footnote - Bold - Secondary
        </Text>

        <Text
          teksttype="footnote"
          weight="bold"
          color="negative"
          stylingclasses="bg-primary p-2 rounded-2xl block"
        >
          Footnote - Bold - Negative
        </Text>
      </div>

      <!-- Label -->
      <div class="my-10 flex flex-col gap-3">
        <Text teksttype="label" weight="light" color="body">
          Label - Light - Body
        </Text>

        <Text teksttype="label" weight="regular" color="body">
          Label - Regular - Body
        </Text>

        <Text teksttype="label" weight="bold" color="body">
          Label - Bold - Body
        </Text>

        <Text teksttype="label" weight="bold" color="primary">
          Label - Bold - Primary
        </Text>

        <Text teksttype="label" weight="bold" color="secondary">
          Label - Bold - Secondary
        </Text>

        <Text
          teksttype="label"
          weight="bold"
          color="negative"
          stylingclasses="bg-primary p-2 rounded-2xl block"
        >
          Label - Bold - Negative
        </Text>
      </div>
    </section><!-- slut på typografi -->

    <hr class="my-4" />
    <!-- Link komponent instanser -->
    <section>
      <Heading htmlheading="h2" size="medium">Links</Heading>
      <Text teksttype="brødtekst"
        ><Link href="#">Default link: </Link>Default linket er en del af en
        tekst, og burde gerne fungere som et <Link href="#">link</Link> i en paragraf.</Text
      >
      <Text><Link href="#" variant="primary">Link variant: primary</Link></Text>
      <Text
        ><Link href="#" variant="primary" size="small"
          >Link variant: primary size small</Link
        ></Text
      >
      <Text
        ><Link href="#" variant="primary" size="medium"
          >Link variant: primary size medium</Link
        ></Text
      >
      <Text
        ><Link href="#" variant="primary" size="large"
          >Link variant: primary size large</Link
        ></Text
      >
      <Text
        ><Link href="#" variant="secondary" size="small"
          >Link variant: secondary size small</Link
        ></Text
      >
      <Text
        ><Link href="#" variant="secondary" size="medium"
          >Link variant: secondary size medium</Link
        ></Text
      >
      <Text
        ><Link href="#" variant="secondary" size="large"
          >Link variant: secondary size large</Link
        ></Text
      >
    </section>
    <!-- Slut på Link komponent instanser -->
    <hr class="my-4" />
    <!-- Buttons komponent instanser -->
    <section>
      <Heading htmlheading="h2" size="medium">Buttons</Heading>
      <Text><Button>Default knap</Button></Text>
      <Text><Button variant="primary">Button variant: primary</Button></Text>
      <Text
        ><Button variant="primary" size="small"
          >Button variant: primary size small</Button
        ></Text
      >
      <Text
        ><Button variant="primary" size="medium"
          >Button variant: primary size medium</Button
        ></Text
      >
      <Text
        ><Button variant="primary" size="large"
          >Button variant: primary size large</Button
        ></Text
      >
      <Text
        ><Button variant="secondary" size="small"
          >Button variant: secondary size small</Button
        ></Text
      >
      <Text
        ><Button variant="secondary" size="medium"
          >Button variant: secondary size medium</Button
        ></Text
      >
      <Text
        ><Button variant="secondary" size="large"
          >Variant: secondary size large</Button
        ></Text
      >
    </section>
    <!-- Slut på Buttons komponent instanser -->
  </main>
</MainLayout>
