---
// Henter parametrene fra Astro.props
const { variant = "primary", size = "responsive", form = "square", type = "button", isActive = false, href = "", target = "_self", ...rest } = Astro.props;

// Base styling
const buttonStyling = "btn filter-btn";

// Variant styling
const variantClasses = {
  primary: "font-bold px-8 py-4 bg-primary text-primary-content focus:bg-accent focus:text-primary focus:border-primary focus:border-2",

  secondary: "font-bold border-2 px-8 py-4 border-primary text-primary bg-neutral hover:border-accent hover:text-accent focus:bg-accent focus:text-primary focus:border-primary",
};

// Active styling
const activeClasses = {
  primary: "bg-[var(--color-surfacedarker)] border-[var(--color-surfacedarker)]",

  secondary: "bg-[var(--color-surfacedarker)] border-[var(--color-surfacedarker)]",
};

// Size styling
const sizeClasses = {
  responsive: "btn-xs sm:btn-sm md:btn-md lg:btn-lg xl:btn-xl",
};

// Shape styling
const formClasses = {
  square: "rounded-none",
  pill: "rounded-full",
};
---

{
  href ? (
    <a href={href} target={target} data-variant={variant} {...rest} class:list={[buttonStyling, variantClasses[variant], sizeClasses[size], formClasses[form], isActive && activeClasses[variant]]}>
      <slot />
    </a>
  ) : (
    <button type={type} data-variant={variant} {...rest} class:list={[buttonStyling, variantClasses[variant], sizeClasses[size], formClasses[form], isActive && activeClasses[variant]]}>
      <slot />
    </button>
  )
}

<style is:inline>
  .is-active {
    background: var(--color-surfacedarker) !important;
    color: var(--color-primary-content) !important;
    border-color: var(--color-surfacedarker) !important;
  }

  .is-active * {
    color: var(--color-primary-content) !important;
  }

  /* Ensure secondary variant children turn accent color on hover/focus, but do not override active text color */
  .filter-btn[data-variant="secondary"]:not(.is-active):hover *,
  .filter-btn[data-variant="secondary"]:not(.is-active):focus * {
    color: var(--color-accent) !important;
  }
</style>

<script is:inline>
  if (typeof window !== "undefined" && !window.__filterButtonsBound) {
    window.__filterButtonsBound = true;

    document.addEventListener("click", (e) => {
      const clickedBtn = e.target.closest(".filter-btn");

      if (!clickedBtn) return;

      // Fjern active fra alle filter knapper
      document.querySelectorAll(".filter-btn").forEach((btn) => {
        btn.classList.remove("is-active");
      });

      // Tilføj active til den klikkede
      clickedBtn.classList.add("is-active");
    });
  }
</script>
