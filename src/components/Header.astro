---
const pathname = new URL(Astro.request.url).pathname;
const currentPath = pathname.slice(1); // remove the first "/"
import Text from "../components/Text.astro";
import Heading from "../components/Heading.astro";
---

<nav class="navbar fixed top-0 left-0 w-full bg-base-100 z-50 px-4 lg:px-8 py-4">
  <!-- LEFT -->
  <div class="flex items-center">
    <a href="/">
      <img src="/img/logo/LogoBlue.png" alt="Crying Wine" class="h-10 lg:h-16 w-auto" />
    </a>
  </div>

  <!-- DESKTOP MENU -->
  <div class="hidden lg:flex">
    <ul class="menu menu-horizontal gap-2">
      <li>
        <a href="/paahylden" class="hover:bg-transparent hover:text-accent transition-colors"> <Text teksttype="subtitle" weight="bold" color="surfacedarker">På hylden</Text> </a>
      </li>

      <li>
        <a href="/bagomcrying" class="hover:bg-transparent hover:text-accent transition-colors"> <Text teksttype="subtitle" weight="bold" color="surfacedarker">Bag om crying</Text> </a>
      </li>

      <li>
        <a href="/flaskentilmaden" class="hover:bg-transparent hover:text-accent transition-colors"> <Text teksttype="subtitle" weight="bold" color="surfacedarker">Flasken til maden</Text> </a>
      </li>
    </ul>
  </div>

  <!-- RIGHT -->
  <div class="ml-auto flex items-center gap-(--gapweb-xs)">
    <!-- SEARCH (desktop only) -->
    <div class="hidden lg:flex items-center border-b border-(var(--color-surfacedarker))">
      <input type="text" placeholder="Søg" class="bg-transparent border-none outline-none placeholder:text-(var(--color-surfacedarker)) w-60 p-0" />
    </div>

    <!-- ACCOUNT ICON -->
    <a href="/konto" class="hidden lg:flex">
      <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class="text-(var(--color-surfacedarker))">
        <path d="M20 21a8 8 0 1 0-16 0"></path>
        <circle cx="12" cy="7" r="4"></circle>
      </svg>
    </a>

    <!-- CART -->
    <!-- Sæt dit eget billede ind her -->
    <img src="/img/illustrations/putikassendark.png" alt="Kurv" class="w-7 h-7" />

    <!-- MOBILE MENU -->
    <div class="lg:hidden relative z-50">
      <!-- hidden checkbox -->
      <input id="mobile-menu" type="checkbox" class="peer hidden" />

      <!-- BUTTON -->
      <label for="mobile-menu" class="cursor-pointer relative z-50 block">
        <!-- hamburger -->
        <svg
          class="block peer-checked:hidden fill-current text-[var(--color-surfacedarker)] transition-all duration-300"
          xmlns="http://www.w3.org/2000/svg"
          width="34"
          height="34"
          viewBox="0 0 512 512"
        >
          <path d="M64,384H448V341.33H64Zm0-106.67H448V234.67H64ZM64,128v42.67H448V128Z"></path>
        </svg>

        <!-- close -->
        <svg class="hidden peer-checked:block fill-current !text-primary-content transition-all duration-300" xmlns="http://www.w3.org/2000/svg" width="34" height="34" viewBox="0 0 512 512">
          <polygon points="400 145.49 366.51 112 256 222.51 145.49 112 112 145.49 222.51 256 112 366.51 145.49 400 256 289.49 366.51 400 400 366.51 289.49 256 400 145.49"></polygon>
        </svg>
      </label>

      <!-- OVERLAY -->
      <div
        class="fixed top-0 right-0 h-screen w-2/3 bg-primary text-primary-content translate-x-full peer-checked:translate-x-0 transition-transform duration-300 ease-in-out z-40 flex flex-col px-8 pt-28"
      >
        <!-- menu -->
        <ul class="flex flex-col gap-8 text-2xl font-semibold text-(var(--color-surfacedarker))">
          <li>
            <a href="/paahylden"><Heading size="medium" color="negative" stylingclasses="text-right">På hylden</Heading></a>
          </li>

          <li>
            <a href="/bagomcrying"><Heading size="medium" color="negative" stylingclasses="text-right">Bag om crying</Heading></a>
          </li>

          <li>
            <a href="/flaskentilmaden"><Heading size="medium" color="negative" stylingclasses="text-right">Flasken til maden</Heading></a>
          </li>
          <li>
            <a href="/"><Heading size="medium" color="negative" stylingclasses="text-right">Login</Heading></a>
          </li>
        </ul>

        <!-- bottom section -->
        <div class="mt-12 flex flex-col">
          <!-- search -->
          <div class="border-b border-primary-content">
            <input type="text" placeholder="Søg" class="bg-transparent border-none outline-none placeholder:text-primary-content w-full text-right p-0 m-0" />
          </div>
        </div>
      </div>
    </div>
  </div>
</nav>
