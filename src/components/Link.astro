---
// Henter parametrene fra Astro.props
const { href = "#", target = "_self", variant = "textlink", size = "default", stylingclasses = "" } = Astro.props;

//Definer den styling (Tailwind classes), der gør sig gældende for de forskellige varianter
const variantClasses = {
  textlink: " text-primary-content hover:text-accent",
  textlinkBlack: " text-secondary-content hover:text-accent",
  primary: "inline-block font-bold px-8 py-4 bg-primary text-primary-content hover:bg-accent",
  secondary: "inline-block font-bold border-2 px-8 py-4 border-primary text-primary bg-neutral hover:text-accent hover:border-accent" /* border-secondary-500 */,
};

//Definer den styling (Tailwind classes), der gør sig gældende for de forskelligeog størrelser.
const sizeClasses = {
  default: "text-[12px] md:text-[13px] lg:text-[14px] uppercase font-",
};
---

<!--Sæt classes for den pågældende knap sammen ved hjælp af Astros class:list -->
<a href={href} target={target} class:list={[variantClasses[variant], sizeClasses[size], stylingclasses]} style={`font-family: var(--font-TextBold);`}><slot /></a>
